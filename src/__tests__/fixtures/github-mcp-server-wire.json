    "id": 1,
    "result": {
      "ttlMs": 0,
      "cacheScope": "public",
      "supportedVersions": ["2026-07-28", "2025-11-25", "2025-06-18", "2025-03-26", "2024-11-05"],
      "capabilities": {
        "completions": {},
        "prompts": {},
        "resources": {},
        "tools": {}
      },
      "serverInfo": {
        "name": "github-mcp-server",
        "title": "GitHub MCP Server",
        "version": "version",
        "icons": [
          { "src": "data:image/png;base64,<TRUNCATED>", "mimeType": "image/png", "theme": "light" },
          { "src": "data:image/png;base64,<TRUNCATED>", "mimeType": "image/png", "theme": "dark" }
        ]
      }
    }
  },

  "new_tools_list_response": {
