  "new_error_32020_header_mismatch": {
    "jsonrpc": "2.0",
    "id": 9,
    "error": {
      "code": -32020,
      "message": "header mismatch: Mcp-Method header value 'prompts/list' does not match body value 'tools/list'"
    }
  },

  "new_error_32602_missing_meta": {
    "jsonrpc": "2.0",
    "id": 10,
    "error": {
      "code": -32602,
      "message": "missing or invalid _meta field \"io.modelcontextprotocol/clientCapabilities\""
    }
  },

